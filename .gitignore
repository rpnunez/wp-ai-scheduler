# Allow the generated autoloader inside ai-post-scheduler/vendor
!ai-post-scheduler/vendor/autoload.php
!ai-post-scheduler/vendor/composer/autoload_classmap.php
!ai-post-scheduler/vendor/composer/autoload_namespaces.php
!ai-post-scheduler/vendor/composer/autoload_psr4.php
!ai-post-scheduler/vendor/composer/autoload_static.php
!ai-post-scheduler/vendor/composer/autoload_real.php
!ai-post-scheduler/vendor/composer/ClassLoader.php
!ai-post-scheduler/vendor/composer/LICENSE
!ai-post-scheduler/vendor/composer/platform_check.php

