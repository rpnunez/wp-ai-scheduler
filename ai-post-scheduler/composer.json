{
  "name": "rpnunez/wp-ai-scheduler",
  "description": "AI Post Scheduler - Schedule AI-generated posts using Meow Apps AI Engine",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Raymond Nunez",
      "email": "raypn93@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "wp-phpunit/wp-phpunit": "^6.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "classmap": [
      "includes/"
    ]
  },
  "autoload-dev": {
    "classmap": [
      "tests/"
    ]
  },
  "scripts": {
    "test": "php vendor/bin/phpunit --configuration phpunit.xml",
    "test:coverage": "php vendor/bin/phpunit --configuration phpunit.xml --coverage-html coverage",
    "test:verbose": "php vendor/bin/phpunit --configuration phpunit.xml --verbose",
    "test:wp:setup": "php tools/setup-wp-phpunit9.php",
    "test:wp": "php tools/phpunit-wp-runner.php --configuration phpunit-wp.xml",
    "test:wp:coverage": "php tools/phpunit-wp-runner.php --configuration phpunit-wp.xml --coverage-html coverage-wp",
    "lint:repository-boundary": "php tools/check-repository-boundary.php"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "process-timeout": 900
  }
}
