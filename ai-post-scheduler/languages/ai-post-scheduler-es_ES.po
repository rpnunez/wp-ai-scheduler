msgid "Generation failed."
msgstr "Error en la generación."

#: assets/js/admin.js
msgid "Run Now"
msgstr "Ejecutar ahora"

#: assets/js/admin.js
msgid "Draft saved successfully."
msgstr "Borrador guardado correctamente."

#: assets/js/admin.js
msgid "Save Draft"
msgstr "Guardar borrador"

#: assets/js/admin.js
msgid "No Voice (Use Default)"
msgstr "Sin voz (usar predeterminada)"

#: assets/js/admin.js
msgid "Add New Voice"
msgstr "Añadir nueva voz"

