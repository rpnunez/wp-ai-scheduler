#. Used as a button label to immediately trigger a scheduled generation run.
#: assets/js/admin.js
msgid "Run Now"
msgstr "Ejecutar ahora"

#. Shown on a save button while a save request is in progress.
#: assets/js/admin.js
msgid "Saving..."
msgstr "Guardando..."

#. Used as a button label to immediately generate a post.
#: assets/js/admin.js
msgid "Generate Now"
msgstr "Generar ahora"

#. Shown while a generation request is in progress.
#: assets/js/admin.js
msgid "Generating..."
msgstr "Generando..."

#. Progress bar label. %s is replaced with a human-readable time string.
#: assets/js/utilities.js
msgid "Estimated time remaining: %s"
msgstr "Tiempo estimado restante: %s"

#. Shown in the progress bar when generation has finished.
#: assets/js/utilities.js
msgid "Generation complete!"
msgstr "¡Generación completada!"
