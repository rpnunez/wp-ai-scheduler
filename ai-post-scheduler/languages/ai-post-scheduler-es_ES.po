#: includes/class-aips-admin-assets.php
msgid "Estimated time remaining: %s"
msgstr "Tiempo estimado restante: %s"

#: includes/class-aips-admin-assets.php
msgid "Generation complete!"
msgstr "¡Generación completada!"

#: includes/class-aips-admin-assets.php
msgid "Taking a little bit longer than expected…"
msgstr "Tarda un poco más de lo esperado…"

#: includes/class-aips-admin-assets.php
msgid "seconds"
msgstr "segundos"

#: includes/class-aips-admin-assets.php
msgid "1 minute"
msgstr "1 minuto"

#. translators: %d: number of minutes
#: includes/class-aips-admin-assets.php
msgid "%d minutes"
msgstr "%d minutos"

