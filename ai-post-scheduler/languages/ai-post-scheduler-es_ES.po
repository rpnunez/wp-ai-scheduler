#: assets/js/admin.js
msgid "Are you sure you want to delete this schedule?"
msgstr "¿Estás seguro de que quieres eliminar esta programación?"

#: assets/js/admin.js
msgid "Please select at least one schedule."
msgstr "Selecciona al menos una programación."

#: assets/js/admin.js
msgid "Are you sure you want to delete 1 schedule?"
msgstr "¿Estás seguro de que quieres eliminar 1 programación?"

#. translators: %d: number of schedules to delete
#: assets/js/admin.js
msgid "Are you sure you want to delete %d schedules?"
msgstr "¿Estás seguro de que quieres eliminar %d programaciones?"

#: assets/js/admin.js
msgid "Failed to load history."
msgstr "Error al cargar el historial."

#: assets/js/admin.js
msgid "Failed to delete schedules."
msgstr "Error al eliminar las programaciones."

#: assets/js/admin.js
msgid "Bulk run failed."
msgstr "Error en la ejecución masiva."

#: assets/js/admin.js
msgid "Run Schedules Now"
msgstr "Ejecutar programaciones ahora"

#: assets/js/admin.js
msgid "Cancel"
msgstr "Cancelar"

#: assets/js/admin.js
msgid "Yes, run now"
msgstr "Sí, ejecutar ahora"

#: assets/js/admin.js
msgid "This will generate an estimated 1 post. Are you sure?"
msgstr "Esto generará un post aproximadamente. ¿Estás seguro?"

#. translators: %d: estimated number of posts to generate
#: assets/js/admin.js
msgid "This will generate an estimated %d posts. Are you sure?"
msgstr "Esto generará aproximadamente %d posts. ¿Estás seguro?"

#: assets/js/admin.js
msgid "This will run 1 schedule. Are you sure?"
msgstr "Esto ejecutará 1 programación. ¿Estás seguro?"

#. translators: %d: number of schedules to run
#: assets/js/admin.js
msgid "This will run %d schedules. Are you sure?"
msgstr "Esto ejecutará %d programaciones. ¿Estás seguro?"

#: assets/js/admin.js
msgid "Delete Schedules"
msgstr "Eliminar programaciones"

#: assets/js/admin.js
msgid "None of the selected schedules can be deleted."
msgstr "Ninguna de las programaciones seleccionadas se puede eliminar."

#: assets/js/admin.js
msgid "The following schedules will be deleted:"
msgstr "Se eliminarán las siguientes programaciones:"

#: assets/js/admin.js
msgid "This action cannot be undone. Continue?"
msgstr "Esta acción no se puede deshacer. ¿Continuar?"

#. translators: %d: number of selected schedules that cannot be deleted
#: assets/js/admin.js
msgid "%d selected schedule(s) cannot be deleted and will be skipped."
msgstr "%d programación(es) seleccionada(s) no se puede(n) eliminar y se omitirá(n)."

#: assets/js/admin.js
msgid "Auto-generate from content"
msgstr "Generar automáticamente desde el contenido"

#: assets/js/admin.js
msgid "None"
msgstr "Ninguno"

#. translators: %s: featured image source name
#: assets/js/admin.js
msgid "Yes (%s)"
msgstr "Sí (%s)"

#: assets/js/admin.js
msgid "Click to copy"
msgstr "Haz clic para copiar"

#: assets/js/admin.js
msgid "Example Topic"
msgstr "Tema de ejemplo"

#: assets/js/admin.js
msgid "Failed to generate preview. Please check that all required fields are filled."
msgstr "Error al generar la vista previa. Comprueba que todos los campos obligatorios estén rellenos."

#: assets/js/admin.js
msgid "An error occurred while generating the preview. Please check your network connection and try again."
msgstr "Se ha producido un error al generar la vista previa. Comprueba tu conexión de red e inténtalo de nuevo."

#: assets/js/admin.js
msgid "Skip the Onboarding Wizard? You can restart it later from System Status."
msgstr "¿Omitir el asistente de incorporación? Puedes reiniciarlo más tarde desde Estado del sistema."

#: assets/js/admin.js
msgid "Please select a bulk action."
msgstr "Selecciona una acción masiva."

