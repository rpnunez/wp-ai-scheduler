{
  "name": "aips/phpunit9-toolchain",
  "description": "Dedicated PHPUnit 9 runner for full WordPress integration tests.",
  "type": "project",
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "preferred-install": "dist",
    "sort-packages": true,
    "process-timeout": 900
  }
}
