<div class="wrap aips-wrap">
	<div class="aips-page-container">
		<div class="aips-page-header">
			<div class="aips-page-header-top">
				<div>
					<h1 class="aips-page-title">{{ t('Trusted Sources') }}</h1>
					<p class="aips-page-description">{{ t('Add URLs that the AI should reference and cite when generating post content. Assign Sources to Source Groups to allow Authors and Templates to selectively include them in their prompts.') }}</p>
				</div>
				<div class="aips-page-actions">
					<button type="button" class="aips-btn aips-btn-secondary" id="aips-manage-source-groups-btn">
						<span class="dashicons dashicons-category"></span>
						{{ t('Manage Groups') }}
					</button>
					<button type="button" class="aips-btn aips-btn-primary" id="aips-add-source-btn">
						<span class="dashicons dashicons-plus-alt2"></span>
						{{ t('Add Source') }}
					</button>
				</div>
			</div>
		</div>

		<div class="aips-content-panel">
			{% include 'partials/sources-list.html.twig' %}
		</div>
	</div>
</div>

{% include 'partials/sources-modals.html.twig' %}
