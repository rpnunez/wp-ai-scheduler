<!-- AI Edit Modal -->
<div id="aips-ai-edit-modal" class="aips-modal" style="display: none;">
	<div class="aips-modal-overlay"></div>
	<div class="aips-modal-content aips-modal-large" style="max-width: 900px; width: 90%;">
		<div class="aips-modal-header">
			<h2>{{ t('AI Edit - Regenerate Components') }}</h2>
			<button type="button" class="aips-modal-close" id="aips-ai-edit-close" aria-label="{{ t('Close')|esc_attr }}">
				<span class="dashicons dashicons-no-alt"></span>
			</button>
		</div>

		<div class="aips-modal-body">
			<div class="aips-ai-edit-loading">
				<div class="spinner is-active"></div>
				<p>{{ t('Loading post components...') }}</p>
			</div>

			<div class="aips-ai-edit-content" style="display: none;">
				<div class="aips-ai-edit-context">
					<h3>{{ t('Original Generation Context') }}</h3>
					<div class="aips-ai-edit-context-grid">
						<div class="aips-ai-edit-context-item"><span class="aips-ai-edit-context-label">{{ t('Template:') }}</span><span class="aips-ai-edit-context-value" id="aips-context-template">—</span></div>
						<div class="aips-ai-edit-context-item"><span class="aips-ai-edit-context-label">{{ t('Author:') }}</span><span class="aips-ai-edit-context-value" id="aips-context-author">—</span></div>
						<div class="aips-ai-edit-context-item"><span class="aips-ai-edit-context-label">{{ t('Topic:') }}</span><span class="aips-ai-edit-context-value" id="aips-context-topic">—</span></div>
					</div>
				</div>

				<div class="aips-component-section" data-component="title">
					<div class="aips-component-header">
						<h4 class="aips-component-title">{{ t('Title') }}</h4>
						<div class="aips-component-actions"><span class="aips-component-status"></span><button type="button" class="aips-regenerate-btn" data-component="title"><span class="dashicons dashicons-update"></span><span class="button-text">{{ t('Re-generate') }}</span></button></div>
					</div>
					<div class="aips-component-body"><input type="text" id="aips-component-title" class="aips-component-input" /><div class="aips-component-meta"><span class="aips-char-count"></span></div></div>
					<div class="aips-component-revisions-wrapper">
						<button type="button" class="aips-view-revisions-btn" data-component="title"><span class="dashicons dashicons-backup"></span><span class="button-text">{{ t('View Revisions') }}</span><span class="revision-count"></span></button>
						<div class="aips-component-revisions" style="display: none;"><div class="aips-revisions-loading"><span class="spinner is-active"></span><span>{{ t('Loading revisions...') }}</span></div><div class="aips-revisions-list"></div><div class="aips-revisions-empty" style="display: none;">{{ t('No previous revisions found.') }}</div></div>
					</div>
				</div>

				<div class="aips-component-section" data-component="excerpt">
					<div class="aips-component-header">
						<h4 class="aips-component-title">{{ t('Excerpt') }}</h4>
						<div class="aips-component-actions"><span class="aips-component-status"></span><button type="button" class="aips-regenerate-btn" data-component="excerpt"><span class="dashicons dashicons-update"></span><span class="button-text">{{ t('Re-generate') }}</span></button></div>
					</div>
					<div class="aips-component-body"><textarea id="aips-component-excerpt" class="aips-component-textarea" rows="4"></textarea><div class="aips-component-meta"><span class="aips-char-count"></span></div></div>
					<div class="aips-component-revisions-wrapper">
						<button type="button" class="aips-view-revisions-btn" data-component="excerpt"><span class="dashicons dashicons-backup"></span><span class="button-text">{{ t('View Revisions') }}</span><span class="revision-count"></span></button>
						<div class="aips-component-revisions" style="display: none;"><div class="aips-revisions-loading"><span class="spinner is-active"></span><span>{{ t('Loading revisions...') }}</span></div><div class="aips-revisions-list"></div><div class="aips-revisions-empty" style="display: none;">{{ t('No previous revisions found.') }}</div></div>
					</div>
				</div>

				<div class="aips-component-section" data-component="content">
					<div class="aips-component-header">
						<h4 class="aips-component-title">{{ t('Content') }}</h4>
						<div class="aips-component-actions"><span class="aips-component-status"></span><button type="button" class="aips-regenerate-btn" data-component="content"><span class="dashicons dashicons-update"></span><span class="button-text">{{ t('Re-generate') }}</span></button></div>
					</div>
					<div class="aips-component-body"><textarea id="aips-component-content" class="aips-component-textarea large" rows="15"></textarea><div class="aips-component-meta"><span class="aips-char-count"></span></div></div>
					<div class="aips-component-revisions-wrapper">
						<button type="button" class="aips-view-revisions-btn" data-component="content"><span class="dashicons dashicons-backup"></span><span class="button-text">{{ t('View Revisions') }}</span><span class="revision-count"></span></button>
						<div class="aips-component-revisions" style="display: none;"><div class="aips-revisions-loading"><span class="spinner is-active"></span><span>{{ t('Loading revisions...') }}</span></div><div class="aips-revisions-list"></div><div class="aips-revisions-empty" style="display: none;">{{ t('No previous revisions found.') }}</div></div>
					</div>
				</div>

				<div class="aips-component-section" data-component="featured_image">
					<div class="aips-component-header">
						<h4 class="aips-component-title">{{ t('Featured Image') }}</h4>
						<div class="aips-component-actions"><span class="aips-component-status"></span><button type="button" class="aips-regenerate-btn" data-component="featured_image"><span class="dashicons dashicons-update"></span><span class="button-text">{{ t('Re-generate') }}</span></button></div>
					</div>
					<div class="aips-component-body"><div class="aips-featured-image-preview"><img id="aips-component-image" src="" alt="{{ t('Featured Image')|esc_attr }}" style="display: none;" /><div id="aips-component-image-none" class="aips-featured-image-none">{{ t('No featured image') }}</div></div></div>
					<div class="aips-component-revisions-wrapper">
						<button type="button" class="aips-view-revisions-btn" data-component="featured_image"><span class="dashicons dashicons-backup"></span><span class="button-text">{{ t('View Revisions') }}</span><span class="revision-count"></span></button>
						<div class="aips-component-revisions" style="display: none;"><div class="aips-revisions-loading"><span class="spinner is-active"></span><span>{{ t('Loading revisions...') }}</span></div><div class="aips-revisions-list"></div><div class="aips-revisions-empty" style="display: none;">{{ t('No previous revisions found for this image.') }}</div></div>
					</div>
				</div>
			</div>
		</div>

		<div class="aips-modal-footer">
			<div class="aips-modal-footer-left"><p>{{ t('Changes marked with * will be saved') }}</p></div>
			<div class="aips-modal-footer-right">
				<button type="button" class="button" id="aips-ai-edit-regenerate-all">{{ t('Regenerate All') }}</button>
				<button type="button" class="button" id="aips-ai-edit-cancel">{{ t('Cancel') }}</button>
				<button type="button" class="button button-primary" id="aips-ai-edit-save">{{ t('Save Changes') }}</button>
			</div>
		</div>
	</div>
</div>
